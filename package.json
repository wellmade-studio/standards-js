{
  "name": "wellmade-standards-js",
  "private": true,
  "type": "module",
  "description": "Wellmade's shared standards for JS/TS projects — ESLint, Prettier, Stylelint configs (more to come).",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "commitlint": "commitlint",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@commitlint/cli": "^19.6.0",
    "@wellmade/commitlint-config": "*",
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.5.1"
  },
  "packageManager": "npm@11.5.1"
}
